  if(!p.bossKills)p.bossKills=0;if(!p.maxCombo)p.maxCombo=0;
  G={p,allTiles,mapKey:savedData?(savedData.mapKey||selWorld):selWorld,
    enemies:[],skillCD:new Array(24).fill(0),
    camX:0,camY:0,t:0,tick:0,running:true,
    spawnTimer:0,bossTimer:180,weather:'clear',wxTimer:30,
    combo:0,comboTimer:0,score:0,
    quests:savedData?savedData.quests:mkQuests(),
    fakePlayers:FAKE_PLAYERS.map(f=>({...f})),
    visitedMaps:new Set([savedData?(savedData.mapKey||selWorld):selWorld]),
    activeBoss:null,
  };
  cvW.style.transform='';
  updatePortrait(p.cls);buildHotbar();buildMobSkills();buildTeleportUI();buildQuickbar();
  document.getElementById('mml').textContent=MAPS[G.mapKey].name;
  for(let i=0;i<5;i++)spawnEnemy();
