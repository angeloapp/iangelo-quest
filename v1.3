function mkWorldSVG(key,w,h){
  const g=WORLD_ART_GRAD[key]||WORLD_ART_GRAD.bosque_oscuro;
  const m=MAPS[key];
  let c='';
  const deco=m.deco;
  c+=`<defs><linearGradient id="wg${key}" x1="0" y1="0" x2="0" y2="1">
    <stop offset="0%" stop-color="${g[0]}"/>
    <stop offset="60%" stop-color="${g[1]}"/>
    <stop offset="100%" stop-color="${g[2]}"/>
  </linearGradient></defs>
  <rect width="${w}" height="${h}" fill="url(#wg${key})"/>`;
  // Stars
  for(let i=0;i<8;i++)c+=`<circle cx="${5+i*w/8.5}" cy="${4+Math.sin(i)*12}" r="${.6+Math.random()}" fill="#c9a84c" opacity=".5"/>`;
  // Terrain
  c+=`<path d="M0 ${h} Q${w*.25} ${h*.55} ${w*.5} ${h*.6} Q${w*.75} ${h*.52} ${w} ${h*.62} L${w} ${h}Z" fill="${g[1]}" opacity=".8"/>`;
  // Atmosphere
  if(m.safe)c+=`<circle cx="${w/2}" cy="${h*.25}" r="15" fill="#ffdd88" opacity=".5"/>`;
  if(m.danger>=4)c+=`<circle cx="${w*.3}" cy="${h*.3}" r="8" fill="#ff4400" opacity=".3"/>`;
  c+=`<text x="${w/2}" y="${h*.48}" font-size="28" text-anchor="middle" font-family="serif">${deco}</text>`;
  return `<svg xmlns="http://www.w3.org/2000/svg" width="${w}" height="${h}" viewBox="0 0 ${w} ${h}">${c}</svg>`;
}
