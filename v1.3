// ── Quests ──
function checkQuest(type,val,isBoss){
  if(!G)return;
  G.quests.forEach(q=>{
    if(q.done)return;
    if(type==='kill'&&q.type==='kill'&&q.target===val){q.progress++;if(q.progress>=q.goal)completeQ(q);}
    if(type==='kill'&&q.type==='boss'&&isBoss&&q.target===val){q.progress++;if(q.progress>=q.goal)completeQ(q);}
    if(type==='map'&&q.type==='map'){q.progress=G.visitedMaps.size;if(q.progress>=q.goal)completeQ(q);}
    if(type==='gold'&&q.type==='gold'){q.progress=G.p.gold;if(q.progress>=q.goal)completeQ(q);}
    if(type==='combo'&&q.type==='combo'){q.progress=Math.max(q.progress,G.combo);if(q.progress>=q.goal)completeQ(q);}
    if(type==='level'&&q.type==='level'){q.progress=G.p.level;if(q.progress>=q.goal)completeQ(q);}
  });
}
function completeQ(q){q.done=true;G.p.xp+=q.reward.xp||0;G.p.gold+=q.reward.gold||0;toast('✅ Quest: '+q.title+' — +'+(q.reward.xp||0)+'XP +'+(q.reward.gold||0)+'G',4000);checkLevelUp();}

