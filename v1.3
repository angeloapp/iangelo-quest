// ══════════════════════════════════════════
function spawnEnemy(forceBoss){
  if(!G)return;
  const m=MAPS[G.mapKey],tiles=G.allTiles[G.mapKey];
  let pool=ENEMIES.filter(e=>!e.boss&&e.lv<=G.p.level+3);
  if(forceBoss)pool=ENEMIES.filter(e=>e.boss&&e.lv<=G.p.level+5);
  if(!pool.length)pool=[ENEMIES[0]];
  const type=pool[Math.floor(Math.random()*pool.length)];
  let x,y,att=0;
  do{x=2+Math.floor(Math.random()*(m.w-4));y=2+Math.floor(Math.random()*(m.h-4));att++;}
  while(att<30&&(!tiles[y]||tiles[y][x]!==0));
  const mul=1+G.p.level*.07;
  const en={...type,id:Math.random().toString(36).slice(2),
    hp:type.hp*mul,maxHp:type.hp*mul,
    px:x*T+T*.5,py:y*T+T*.5,atkTimer:1.5+Math.random(),
    dead:false,flash:0,wobble:0,dotTimer:0,dotDmg:0};
  G.enemies.push(en);
  if(type.boss){G.activeBoss=en;showBossWarn(type.name);showBossBar(en);screenShake(14);}
}

// ── Boss bar ──
function showBossBar(en){
  const bar=document.getElementById('boss-bar');
  document.getElementById('boss-bar-name').textContent='⚠ '+en.name.toUpperCase()+' ⚠';
  bar.classList.add('on');updateBossBar(en);
}
function hideBossBar(){document.getElementById('boss-bar').classList.remove('on');}
function updateBossBar(en){
  if(!en)return;
  const pct=Math.max(0,Math.min(100,en.hp/en.maxHp*100));
  document.getElementById('boss-hp-fill').style.width=pct+'%';
  document.getElementById('boss-hp-val').textContent=Math.ceil(en.hp)+' / '+Math.ceil(en.maxHp);
}

// ══════════════════════════════════════════
//  UPDATE LOOP
// ══════════════════════════════════════════
function update(dt){
  if(!G||!G.running)return;
  const p=G.p,mdb=MAPS[G.mapKey],tiles=G.allTiles[G.mapKey];
  G.t+=dt;G.tick++;G.spawnTimer-=dt;G.comboTimer-=dt;G.bossTimer-=dt;
  if(G.comboTimer<=0&&G.combo>0){G.combo=0;updateComboUI();}
  p.mp=Math.min(p.maxMp,p.mp+(mdb.safe?15:CLASSES[p.cls].mpR)*dt);
  if(mdb.safe)p.hp=Math.min(p.maxHp,p.hp+8*dt);
  for(let i=0;i<G.skillCD.length;i++)G.skillCD[i]=Math.max(0,G.skillCD[i]-dt);
  p.buffs=p.buffs.filter(b=>{b.dur-=dt;return b.dur>0;});
  if(G.spawnTimer<=0&&!mdb.safe&&G.enemies.filter(e=>!e.dead).length<4+p.level){spawnEnemy(false);G.spawnTimer=Math.max(1.5,4-p.level*.1);}
  if(G.bossTimer<=0&&!mdb.safe){G.bossTimer=150+Math.random()*80;if(p.kills>0)setTimeout(()=>spawnEnemy(true),2200);}
  // Player movement
  if(p.moveTarget){
    const dx=p.moveTarget.px-p.px,dy=p.moveTarget.py-p.py,d=Math.hypot(dx,dy);
    if(d<5){p.px=p.moveTarget.px;p.py=p.moveTarget.py;p.moveTarget=null;}
    else{const s=(p.mount?p.speed*p.mount.spdM:p.speed)*dt;p.px+=dx/d*s;p.py+=dy/d*s;}
  }
  if(p.attackTarget&&!p.attackTarget.dead){
    const en=p.attackTarget,d=Math.hypot(en.px-p.px,en.py-p.py);
    if(d>T*1.4){const s=(p.mount?p.speed*p.mount.spdM:p.speed)*dt;p.px+=(en.px-p.px)/d*s;p.py+=(en.py-p.py)/d*s;}
    else if(G.skillCD[0]<=0)doSkill(0,[en]);
  }else if(p.attackTarget&&p.attackTarget.dead)p.attackTarget=null;
  // Enemies AI
  for(const en of G.enemies){
    if(en.dead)continue;
    en.flash=Math.max(0,en.flash-dt);en.wobble=Math.max(0,en.wobble-dt);
    if(en.dotTimer>0){en.dotTimer-=dt;if(G.tick%22===0&&en.hp>0){en.hp-=en.dotDmg;spawnFD(en.px,en.py-T*.5,en.dotDmg,'#88ff44');}}
    if(!mdb.safe){
      const dx=p.px-en.px,dy=p.py-en.py,d=Math.hypot(dx,dy);
      if(d>T*.8){const s=en.spd*65*dt;en.px+=dx/d*s;en.py+=dy/d*s;}
      en.atkTimer-=dt;
      if(en.atkTimer<=0&&d<T*1.05){
        const shld=p.buffs.find(b=>b.type==='shield');
        let dmg=en.atk[0]+Math.random()*(en.atk[1]-en.atk[0]);
        dmg=Math.max(1,dmg-p.def);
        // Curse debuff on enemies
        const cursed=en.cursed;if(cursed)dmg*=.7;
        if(shld){shld.dur-=1.5;if(shld.dur<=0)p.buffs=p.buffs.filter(b=>b!==shld);dmg=0;toast('🛡️ Escudo absorbió el golpe!');}
        p.hp-=dmg;
        if(dmg>0)spawnFD(p.px,p.py-T*.6,'-'+Math.ceil(dmg),'#ff6666');
        log(en.name+' te golpea −'+Math.ceil(dmg),'dmg');
        en.atkTimer=1.4+Math.random();screenShake(3);
        if(p.hp<=0){p.hp=0;gameOver();return;}
      }
    }
    if(en.hp<=0)killEnemy(en);
    // Update boss bar live
    if(en===G.activeBoss&&!en.dead)updateBossBar(en);
  }
  G.fakePlayers.forEach(fp=>{fp.px+=(Math.random()*5-2.5);fp.py+=(Math.random()*5-2.5);});
  G.wxTimer-=dt;if(G.wxTimer<=0){G.weather=mdb.wx||'clear';G.wxTimer=25+Math.random()*30;}
  drawWeather(dt);
  const m=MAPS[G.mapKey];
  const tX=p.px-window.innerWidth/2,tY=p.py-window.innerHeight/2;
  const maxX=Math.max(0,m.w*T-window.innerWidth),maxY=Math.max(0,m.h*T-window.innerHeight);
  G.camX+=(Math.max(0,Math.min(maxX,tX))-G.camX)*.13;
  G.camY+=(Math.max(0,Math.min(maxY,tY))-G.camY)*.13;
  if(!isFinite(G.camX))G.camX=0;if(!isFinite(G.camY))G.camY=0;
  if(shakeAmt>.4){cvW.style.transform='translate('+((Math.random()-.5)*shakeAmt)+'px,'+((Math.random()-.5)*shakeAmt)+'px)';shakeAmt*=.80;}
  else{cvW.style.transform='';shakeAmt=0;}
  checkAchievements();checkQuest('level');checkQuest('gold');
  updateHUD();drawMinimap();
}

function screenShake(a){shakeAmt=Math.max(shakeAmt,a);}

// ══════════════════════════════════════════
//  DRAW BG
// ══════════════════════════════════════════
function drawBg(){
  ctxBg.fillStyle='#050403';ctxBg.fillRect(0,0,cvBg.width,cvBg.height);
  for(const s of stars){
    s.a+=s.s;
    ctxBg.fillStyle='rgba(225,195,130,'+(.2+.45*Math.abs(Math.sin(s.a))).toFixed(2)+')';
    ctxBg.fillRect(s.x,s.y,s.r,s.r);
  }
}

// ══════════════════════════════════════════
//  DRAW WORLD
// ══════════════════════════════════════════
function drawWorld(){
  if(!G||!G.running)return;
  const{mapKey,camX,camY,p,enemies,fakePlayers,t}=G;
  const m=MAPS[mapKey],tiles=G.allTiles[mapKey];
  ctxW.clearRect(0,0,cvW.width,cvW.height);
  ctxW.save();ctxW.translate(-camX,-camY);
  // Tiles
  for(let y=0;y<m.h;y++)for(let x=0;x<m.w;x++){
    if(!tiles[y])continue;
    const tile=tiles[y][x];
    ctxW.fillStyle=tile===0?m.floor:(tile===1?m.wall:'#111');
    ctxW.fillRect(x*T,y*T,T,T);
    ctxW.strokeStyle='rgba(0,0,0,.16)';ctxW.lineWidth=.4;ctxW.strokeRect(x*T,y*T,T,T);
    if(tile===1&&m.deco){ctxW.font='24px serif';ctxW.textAlign='center';ctxW.fillText(m.deco,x*T+T*.5,y*T+T-4);}
  }
  // Move target
  if(p.moveTarget){
    const pulse=(Math.sin(t*8)+1)*.5;
    ctxW.beginPath();ctxW.arc(p.moveTarget.px,p.moveTarget.py,7+pulse*3,0,Math.PI*2);
    ctxW.strokeStyle='rgba(200,170,80,'+(.35+pulse*.45)+')';ctxW.lineWidth=2;ctxW.stroke();
  }
  // Fake players
  for(const fp of fakePlayers){
    if(fp.map!==mapKey)continue;
    ctxW.save();ctxW.translate(fp.px,fp.py);
    ctxW.shadowBlur=10;ctxW.shadowColor=fp.col;
    const img=SVG_CACHE[fp.svgId];
    if(img)ctxW.drawImage(img,-16,-36,32,36);
    ctxW.shadowBlur=0;
    ctxW.font='9px Cinzel,serif';ctxW.fillStyle=fp.col;ctxW.textAlign='center';
    ctxW.fillText(fp.name,0,-42);ctxW.restore();
  }
  // Enemy shadows
  for(const en of enemies){
    if(en.dead)continue;
    ctxW.beginPath();ctxW.ellipse(en.px,en.py+T*.38,T*.34,T*.1,0,0,Math.PI*2);
    ctxW.fillStyle='rgba(0,0,0,.32)';ctxW.fill();
  }
  // Enemies
  for(const en of enemies){
    if(en.dead)continue;
    const szM=en.boss?1.55:1;const sw=T*szM*1.65,sh=T*szM*1.85;
    ctxW.save();ctxW.translate(en.px,en.py);
    if(en.wobble>0)ctxW.rotate(Math.sin(en.wobble*22)*.16);
    if(en.flash>0)ctxW.globalAlpha=.4+.6*Math.abs(Math.sin(en.flash*45));
    ctxW.shadowBlur=en.boss?26:11;ctxW.shadowColor=en.col;
    const img=SVG_CACHE[en.svgId];
    if(img)ctxW.drawImage(img,-sw/2,-sh*.88,sw,sh);
    else{ctxW.font=(en.boss?'40px':'28px')+' serif';ctxW.textAlign='center';ctxW.fillText('👾',0,T*.2);}
    ctxW.restore();
    // HP bar
    const bw=T*(en.boss?2.3:1.3),bh=en.boss?8:5;
    const bx=en.px-bw*.5,by=en.py-T*(en.boss?1.05:.7);
    ctxW.fillStyle='#111';ctxW.fillRect(bx,by,bw,bh);
    const pct=Math.max(0,Math.min(1,en.hp/en.maxHp));
    ctxW.fillStyle=pct>.5?'#44cc44':pct>.25?'#ccaa22':'#cc2222';
    ctxW.fillRect(bx,by,bw*pct,bh);
    if(en.boss){ctxW.font='10px Cinzel,serif';ctxW.fillStyle='#ff5555';ctxW.textAlign='center';ctxW.fillText('⚠ '+en.name,en.px,en.py-T*1.12);}
    if(p.attackTarget===en){ctxW.beginPath();ctxW.arc(en.px,en.py,T*.54+Math.sin(G.t*4)*2.5,0,Math.PI*2);ctxW.strokeStyle='rgba(255,200,50,.55)';ctxW.lineWidth=2;ctxW.stroke();}
  }
  // Player shadow
  ctxW.beginPath();ctxW.ellipse(p.px,p.py+T*.4,T*.32,T*.1,0,0,Math.PI*2);ctxW.fillStyle='rgba(0,0,0,.38)';ctxW.fill();
  // Player glow
  const gx=isFinite(p.px)?p.px:0,gy=isFinite(p.py)?p.py:0;
  try{const grd=ctxW.createRadialGradient(gx,gy,0,gx,gy,T);grd.addColorStop(0,CLASSES[p.cls].col+'2a');grd.addColorStop(1,'transparent');ctxW.fillStyle=grd;ctxW.beginPath();ctxW.arc(gx,gy,T,0,Math.PI*2);ctxW.fill();}catch(e){}
  // Pet
  if(p.pet){ctxW.save();ctxW.translate(p.px-52,p.py+10);ctxW.shadowBlur=14;ctxW.shadowColor='#aa44ff';ctxW.font='24px serif';ctxW.textAlign='center';ctxW.fillText(p.pet.emoji,0,0);ctxW.font='8px Cinzel,serif';ctxW.fillStyle='#aa44ff';ctxW.fillText(p.pet.name,0,-13);ctxW.restore();}
  // Mount
  if(p.mount){ctxW.save();ctxW.translate(p.px+52,p.py+10);ctxW.shadowBlur=12;ctxW.shadowColor='#ffaa44';ctxW.font='22px serif';ctxW.textAlign='center';ctxW.fillText(p.mount.emoji,0,0);ctxW.restore();}
  // Player sprite
  ctxW.save();ctxW.translate(p.px,p.py);
  ctxW.shadowBlur=24;ctxW.shadowColor=CLASSES[p.cls].col;
  const pImg=SVG_CACHE[CLASSES[p.cls].svgId];
  if(pImg)ctxW.drawImage(pImg,-24,-58,48,62);
  else{ctxW.font='32px serif';ctxW.textAlign='center';ctxW.fillText(CLASSES[p.cls].icon,0,T*.3);}
  if(p.title){ctxW.font='8px Cinzel,serif';ctxW.fillStyle='rgba(240,208,80,.85)';ctxW.textAlign='center';ctxW.fillText('〔'+p.title+'〕',0,-T*.96);}
  ctxW.font='bold 11px Cinzel,serif';ctxW.fillStyle=CLASSES[p.cls].col;ctxW.textAlign='center';
  ctxW.fillText('Lv'+p.level,0,-T*.74);
  ctxW.restore();
  ctxW.restore();
}

// ── Weather ──
function drawWeather(dt){
  if(!G||G.weather==='clear'){ctxWx.clearRect(0,0,cvWx.width,cvWx.height);wxParts=[];return;}
  const need=G.weather==='storm'?300:G.weather==='rain'?170:60;
  while(wxParts.length<need)wxParts.push({x:Math.random()*cvWx.width,y:Math.random()*cvWx.height,vy:G.weather==='fog'?.5:3.5+Math.random()*4,vx:G.weather==='storm'?-2.5-Math.random()*3:-.4,len:G.weather==='fog'?0:6+Math.random()*11,al:.14+Math.random()*.26});
  ctxWx.clearRect(0,0,cvWx.width,cvWx.height);
  if(G.weather==='fog'){ctxWx.fillStyle='rgba(88,98,108,.12)';ctxWx.fillRect(0,0,cvWx.width,cvWx.height);}
  ctxWx.strokeStyle='rgba(155,190,255,.44)';ctxWx.lineWidth=.9;
  for(const wp of wxParts){
    wp.x+=wp.vx;wp.y+=wp.vy*60*dt;
    if(wp.y>cvWx.height){wp.y=0;wp.x=Math.random()*cvWx.width;}
    if(G.weather!=='fog'){ctxWx.globalAlpha=wp.al;ctxWx.beginPath();ctxWx.moveTo(wp.x,wp.y);ctxWx.lineTo(wp.x+wp.vx*1.4,wp.y-wp.len);ctxWx.stroke();}
  }
  ctxWx.globalAlpha=1;
  if(G.weather==='storm'&&Math.random()<.004){ctxWx.fillStyle='rgba(255,255,255,.05)';ctxWx.fillRect(0,0,cvWx.width,cvWx.height);}
}

// ══════════════════════════════════════════
//  SKILLS — VOCATION SYSTEM
// ══════════════════════════════════════════
function getCurSkills(){return VOC_SKILLS[G?G.p.cls:0]||VOC_SKILLS[0];}

function doSkill(idx,targets){
  if(!G)return;
  const skills=getCurSkills();
  const sk=skills[idx];if(!sk)return;
  const p=G.p;
  if(G.skillCD[idx]>0||p.mp<sk.cost){if(p.mp<sk.cost)log('MP insuficiente','sys');return;}
  p.mp-=sk.cost;G.skillCD[idx]=sk.cd;startCdAnim(idx);

  // Buff types
  if(sk.type==='buff'){
    if(sk.buff==='shield')p.buffs.push({type:'shield',dur:12,maxDur:12,icon:'🛡️'});
    if(sk.buff==='atk')p.buffs.push({type:'atk',dur:15,maxDur:15,icon:'⚔️',mult:1.3});
    if(sk.buff==='crit')p.buffs.push({type:'crit',dur:12,maxDur:12,icon:'🎯',critBonus:.5});
    toast('✨ '+sk.name+' activado!');burst(p.px,p.py,sk.col,14);return;
  }
  if(sk.type==='debuff'){
    if(!targets||!targets.length){if(p.attackTarget&&!p.attackTarget.dead)targets=[p.attackTarget];else{log('Sin objetivo','sys');return;}}
    for(const en of targets){if(!en.dead){en.cursed=8;en.spd*=.7;spawnFD(en.px,en.py-T*.7,'☠MALDITO',sk.col);}}
    toast('🪄 '+sk.name+' aplicado!');return;
  }
  if(sk.type==='heal'){
    const h=(sk.heal[0]+Math.random()*(sk.heal[1]-sk.heal[0]))|0;
    const intBonus=Math.round(p.int*1.2);
    p.hp=Math.min(p.maxHp,p.hp+h+intBonus);
    spawnFD(p.px,p.py-T,'+'+(h+intBonus),'#44ee88');
    log(sk.name+' +'+(h+intBonus)+' HP','heal');burst(p.px,p.py,sk.col,16);return;
  }
  // Damage skills
  if(sk.type==='aoe'||sk.type==='dot'){
    const r=T*(sk.type==='aoe'?3.8:2.4);
    targets=G.enemies.filter(e=>!e.dead&&Math.hypot(e.px-p.px,e.py-p.py)<r);
    if(!targets.length){if(p.attackTarget&&!p.attackTarget.dead)targets=[p.attackTarget];else{log('Sin objetivo','sys');return;}}
  }else if(!targets||!targets.length){
    if(p.attackTarget&&!p.attackTarget.dead)targets=[p.attackTarget];else{log('Sin objetivo','sys');return;}
  }
  const atkBuff=p.buffs.find(b=>b.type==='atk');
  const critBuff=p.buffs.find(b=>b.type==='crit');
  for(const en of targets){
    if(en.dead)continue;
    let dmg=(sk.dmg[0]+Math.random()*(sk.dmg[1]-sk.dmg[0]))|0;
    dmg+=p.level*3+Math.round(p.str*1.7);
    if(atkBuff)dmg=Math.round(dmg*atkBuff.mult);
    const critChance=p.critChance+(critBuff?critBuff.critBonus:0);
    const isCrit=Math.random()<critChance;
    if(isCrit){dmg=Math.round(dmg*2.2);spawnFD(en.px,en.py-T*.7,'💥CRIT '+dmg,sk.col,true);screenShake(9);}
    else spawnFD(en.px,en.py-T*.58,dmg,sk.col);
    en.hp-=dmg;en.flash=.18;en.wobble=.24;p.totalDmg+=dmg;
    if(sk.type==='dot'){en.dotTimer=5;en.dotDmg=Math.round(dmg*.15);}
    if(p.pet&&!en.dead){const pd=Math.round(dmg*p.pet.dmgM);en.hp-=pd;p.totalDmg+=pd;spawnFD(en.px-28,en.py-T*.7,pd,'#aa44ff');}
    G.combo++;G.comboTimer=3;
    if(G.combo>p.maxCombo)p.maxCombo=G.combo;
    updateComboUI();checkQuest('combo');
    burst(en.px,en.py,sk.col,sk.type==='aoe'?20:10);
    log(sk.name+' → '+en.name+' '+dmg+(isCrit?' 💥':''),'dmg');
    if(en.hp<=0)killEnemy(en);
  }
}

function useSkill(idx){if(!G||!G.running)return;doSkill(idx,G.p.attackTarget?[G.p.attackTarget]:[]);}

// Quick potion use
function quickUsePotion(){
  if(!G)return;
  const inv=G.p.inventory;
  const pi=inv.findIndex(i=>i.type==='consumable'&&i.heal);
  if(pi===-1){toast('Sin pociones en inventario');return;}
  const item=inv[pi];
  G.p.hp=Math.min(G.p.maxHp,G.p.hp+item.heal);
  log('🧪 +'+item.heal+' HP','heal');toast('🧪 Poción usada! +'+item.heal+' HP');
  spawnFD(G.p.px,G.p.py-T,'+'+item.heal,'#44ee88');
  item.count=(item.count||1)-1;if(item.count<=0)inv.splice(pi,1);
  updateHUD();buildQuickbar();
}

// ══════════════════════════════════════════
//  KILL & LOOT
// ══════════════════════════════════════════
function killEnemy(en){
  if(en.dead)return;en.dead=true;
  const p=G.p;p.kills++;
  if(en.boss){p.bossKills++;screenShake(16);hideBossBar();G.activeBoss=null;}
  p.xp+=en.xp;p.gold+=(en.gold[0]+Math.random()*(en.gold[1]-en.gold[0]))|0;G.score+=en.xp;
  burst(en.px,en.py,en.col,en.boss?45:20);
  log(en.name+' derrotado! +'+en.xp+'XP','xp');
  if(en.boss)toast('🏆 JEFE DERROTADO — '+en.name+'!',5000);
  dropLoot(en);checkQuest('kill',en.name,en.boss);checkLevelUp();checkAchievements();
  if(p.kills>=60)gameWin();
}

function dropLoot(en){
  if(Math.random()>en.drop)return;
  const roll=Math.random();
  const rar=en.boss?(roll>.5?'epic':roll>.15?'rare':'legend'):(roll>.94?'legend':roll>.75?'epic':roll>.45?'rare':'common');
  const pool=SHOP_ITEMS.filter(i=>i.rarity===rar);if(!pool.length)return;
  const item={...pool[Math.floor(Math.random()*pool.length)],id:Date.now()};
  G.p.inventory.push(item);
  const el=document.createElement('div');el.className='lootfx';
  el.style.left=(en.px-G.camX-14)+'px';el.style.top=(en.py-G.camY-40)+'px';
  el.style.color=rar==='legend'?'#f0d070':rar==='epic'?'#cc44ff':rar==='rare'?'#6688ff':'#aaa';
  el.textContent=item.icon+(rar==='legend'?'★':rar==='epic'?'◆':'');
  document.body.appendChild(el);setTimeout(()=>el.remove(),2400);
  if(rar==='legend'||rar==='epic')toast('💎 DROP '+rar.toUpperCase()+' → '+item.name+'!',4000);
  log('💰 Loot: '+item.name+' ['+rar+']','loot');
  buildQuickbar();
}

// ── Level up ──
function checkLevelUp(){
  const p=G.p;
  while(p.xp>=p.xpNext){
    p.xp-=p.xpNext;p.level++;
    p.xpNext=Math.floor(150*Math.pow(1.43,p.level-1));
    p.maxHp+=32+p.vit*2;p.hp=p.maxHp;p.maxMp+=20+p.int;p.mp=p.maxMp;
    p.def+=2;p.statPts+=3;p.speed+=1.5;
    log('🎉 ¡NIVEL '+p.level+'! +3 puntos','sys');toast('⭐ ¡Nivel '+p.level+' alcanzado!');
    const f=document.getElementById('lvfl');f.style.display='block';
