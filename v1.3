// SVG image cache
const SVG_CACHE = {};
function svgToImg(id,w,h){
  return new Promise(r=>{
    if(SVG_CACHE[id]){r(SVG_CACHE[id]);return;}
    const sym=document.querySelector('symbol#'+id);if(!sym){r(null);return;}
    const vb=sym.getAttribute('viewBox')||'0 0 '+w+' '+h;
    const svgStr=`<svg xmlns="http://www.w3.org/2000/svg" width="${w}" height="${h}" viewBox="${vb}">${sym.innerHTML}</svg>`;
    const blob=new Blob([svgStr],{type:'image/svg+xml'});
    const url=URL.createObjectURL(blob);
    const img=new Image();
    img.onload=()=>{SVG_CACHE[id]=img;URL.revokeObjectURL(url);r(img);};
    img.onerror=()=>r(null);
    img.src=url;
  });
}
async function preloadSVGs(){
  const ids=['hero-guerrero','hero-mago','hero-arquero','hero-chaman','enemy-goblin','enemy-esqueleto','enemy-lobo','enemy-metin','enemy-dragon','enemy-lich'];
  for(const id of ids)await svgToImg(id,100,100);
}

