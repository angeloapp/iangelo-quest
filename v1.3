// ── Inventory ──
function renderInv(){
  if(!G)return;const p=G.p;
  let h='<div style="display:flex;gap:12px;flex-wrap:wrap;">';
  h+='<div style="min-width:180px"><div style="font-family:Cinzel,serif;color:var(--gold);margin-bottom:6px">Equipado</div><div style="display:flex;gap:6px;flex-wrap:wrap">';
  ['weapon','armor','accessory'].forEach(sl=>{
    const it=p.equipped[sl];
    h+='<div class="isl '+(it?'eq':'emp')+'" onclick="unequip(\''+sl+'\')">';
    if(it)h+='<span style="font-size:1.55rem">'+it.icon+'</span><span style="font-size:.56rem">'+it.name+'</span>';
    else h+='<span style="font-size:.58rem;color:var(--dim)">'+sl+'</span>';
    h+='</div>';
  });
  h+='</div></div>';
  h+='<div style="flex:2;min-width:220px"><div style="font-family:Cinzel,serif;color:var(--gold);margin-bottom:6px">Bolsa ('+p.inventory.length+')</div><div class="igrid">';
  p.inventory.forEach((item,i)=>{
    const r=item.rarity||'common';
    const stat=item.atk?'+'+item.atk+' ATK':item.def?'+'+item.def+' DEF':item.heal?'+'+item.heal+' HP':item.crit?(item.crit*100).toFixed(0)+'% CRT':'';
    h+='<div class="isl" onclick="useOrEquip('+i+')">'
      +'<span style="font-size:1.65rem">'+item.icon+'</span>'
      +'<span style="font-size:.56rem">'+item.name+(item.count&&item.count>1?' x'+item.count:'')+'</span>'
      +'<span style="color:var(--gold);font-size:.54rem">'+stat+'</span>'
      +'<span class="tag '+r+'">'+r+'</span></div>';
  });
  h+='</div></div></div>';
  document.getElementById('inv-c').innerHTML=h;
}
function useOrEquip(i){
  if(!G)return;const item=G.p.inventory[i];if(!item)return;
  if(item.type==='consumable'){
    if(item.heal){G.p.hp=Math.min(G.p.maxHp,G.p.hp+item.heal);log('🧪 +'+item.heal+' HP','heal');}
    if(item.mp){G.p.mp=Math.min(G.p.maxMp,G.p.mp+item.mp);log('💧 +'+item.mp+' MP','heal');}
    if(item.xpGain){G.p.xp+=item.xpGain;checkLevelUp();log('✨ +'+item.xpGain+' XP','xp');}
    item.count=(item.count||1)-1;if(item.count<=0)G.p.inventory.splice(i,1);
  }else{
    const sl=item.type==='helm'?'armor':item.type;
    if(['weapon','armor','accessory'].includes(sl)){
      if(G.p.equipped[sl])G.p.inventory.push(G.p.equipped[sl]);
      G.p.equipped[sl]=item;G.p.inventory.splice(i,1);
      toast('⚔️ '+item.name+' equipado!');
      if(item.crit)G.p.critChance=Math.min(.5,G.p.critChance+item.crit);
      if(item.spdBonus)G.p.speed+=item.spdBonus;
    }
  }
  updateHUD();renderInv();buildQuickbar();
}
function unequip(sl){if(!G||!G.p.equipped[sl])return;G.p.inventory.push(G.p.equipped[sl]);G.p.equipped[sl]=null;renderInv();}

