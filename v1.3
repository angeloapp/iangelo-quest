cvW.addEventListener('click',e=>{
  if(!G||!G.running)return;
  const wx=e.clientX+G.camX,wy=e.clientY+G.camY;
  for(const en of G.enemies){if(!en.dead&&Math.hypot(en.px-wx,en.py-wy)<T*.85){G.p.attackTarget=en;G.p.moveTarget=null;return;}}
  const tx=Math.floor(wx/T),ty=Math.floor(wy/T);
  const tiles=G.allTiles[G.mapKey],m=MAPS[G.mapKey];
  if(tx>=0&&tx<m.w&&ty>=0&&ty<m.h&&tiles[ty]&&tiles[ty][tx]===0){G.p.moveTarget={px:tx*T+T*.5,py:ty*T+T*.5};G.p.attackTarget=null;}
});

document.addEventListener('keydown',e=>{
  if(!G||!G.running)return;
  const km={'1':0,'2':1,'3':2,'4':3,'5':4,'6':5};
  if(km[e.key]!==undefined){useSkill(km[e.key]);return;}
  if(e.key==='Escape'){closeAllM();return;}
  if(e.key==='i'||e.key==='I'){openM('inventory');return;}
  if(e.key==='q'||e.key==='Q'){openM('quests');return;}
  if(e.key==='t'||e.key==='T'){openM('teleport');return;}
  if(e.key==='p'||e.key==='P'){togglePet();return;}
  if(e.key==='m'||e.key==='M'){toggleMount();return;}
  if(e.key==='c'||e.key==='C'){toggleChat();return;}
  if(e.key==='f'||e.key==='F'){quickUsePotion();return;}
  const spd=T;
  if(e.key==='w'||e.key==='ArrowUp')   G.p.moveTarget={px:G.p.px,py:G.p.py-spd};
  if(e.key==='s'||e.key==='ArrowDown') G.p.moveTarget={px:G.p.px,py:G.p.py+spd};
  if(e.key==='a'||e.key==='ArrowLeft') G.p.moveTarget={px:G.p.px-spd,py:G.p.py};
  if(e.key==='d'||e.key==='ArrowRight')G.p.moveTarget={px:G.p.px+spd,py:G.p.py};
});

// ── MOBILE JOYSTICK ──
let joyActive=false,joyBase={x:0,y:0},joyDx=0,joyDy=0;
const joyZone=document.getElementById('joy-zone');
const joyStick=document.getElementById('joy-stick');
const joyBaseEl=document.getElementById('joy-base');

function joyStart(e){
  e.preventDefault();
  joyActive=true;
  const t=e.touches?e.touches[0]:e;
  const r=joyBaseEl.getBoundingClientRect();
  joyBase={x:r.left+r.width/2,y:r.top+r.height/2};
}
function joyMove(e){
  e.preventDefault();if(!joyActive)return;
  const t=e.touches?e.touches[0]:e;
  const dx=t.clientX-joyBase.x,dy=t.clientY-joyBase.y;
  const d=Math.hypot(dx,dy);const maxR=45;
  const cx=d>maxR?dx/d*maxR:dx,cy=d>maxR?dy/d*maxR:dy;
  joyStick.style.transform=`translate(calc(-50% + ${cx}px),calc(-50% + ${cy}px))`;
  joyDx=cx/maxR;joyDy=cy/maxR;
}
function joyEnd(e){
  joyActive=false;joyDx=0;joyDy=0;
  joyStick.style.transform='translate(-50%,-50%)';
}
joyBaseEl.addEventListener('touchstart',joyStart,{passive:false});
document.addEventListener('touchmove',joyMove,{passive:false});
document.addEventListener('touchend',joyEnd);

function applyJoystick(){
  if(!G||!G.running||!joyActive||(!joyDx&&!joyDy))return;
  const spd=4.5;
  G.p.moveTarget={px:G.p.px+joyDx*T*spd,py:G.p.py+joyDy*T*spd};
}

function mobAutoAtk(){
  if(!G||!G.running)return;
  if(G.p.attackTarget&&G.p.attackTarget.dead)G.p.attackTarget=null;
  if(!G.p.attackTarget){
    // Auto-target nearest
    let near=null,nd=9999;
    for(const en of G.enemies){if(!en.dead){const d=Math.hypot(en.px-G.p.px,en.py-G.p.py);if(d<nd){nd=d;near=en;}}}
    if(near)G.p.attackTarget=near;
  }
  if(G.p.attackTarget)useSkill(0);
}

