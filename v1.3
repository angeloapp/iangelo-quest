<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>iAngelo Quest V2 — Leyenda Definitiva</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700;900&family=Cinzel+Decorative:wght@700;900&family=IM+Fell+English:ital@0;1&display=swap');
:root{
  --gold:#c9a84c;--gold2:#f0d070;--gold3:#7a5c1e;
  --blood:#cc2222;--blood2:#ff4444;
  --dark:#050403;--dark2:#0d0a07;--dark3:#1a1410;
  --stone:#1e1810;--stone2:#2a2218;--stone3:#3a3025;
  --text:#e8d5a0;--muted:#8a7a55;--dim:#3a2a15;
  --fire:#ff6622;--ice:#88ddff;--pois:#44ff88;--shad:#aa44ff;
  --ui-bg:rgba(5,4,3,0.92);--ui-b:2px solid rgba(201,168,76,0.45);
  --r:6px;--tr:0.18s cubic-bezier(0.4,0,0.2,1);
  --gg:0 0 18px rgba(201,168,76,.4),0 0 36px rgba(201,168,76,.2);
}
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
html,body{width:100%;height:100%;overflow:hidden;}
body{background:var(--dark);color:var(--text);font-family:'IM Fell English',serif;touch-action:none;}
canvas{position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;}
#cW{z-index:1;pointer-events:all;}
#cFx{z-index:2;}
#cWx{z-index:3;}

/* ── TITLE ── */
#title{position:fixed;inset:0;z-index:300;display:flex;flex-direction:column;align-items:center;
  justify-content:center;background:radial-gradient(ellipse 90% 90% at 50% 40%,#180e04,#050403);overflow:hidden;}
.tparts{position:absolute;inset:0;overflow:hidden;pointer-events:none;}
.tp{position:absolute;border-radius:50%;animation:tpR linear infinite;opacity:0;}
@keyframes tpR{0%{opacity:0;transform:translateY(0)scale(0)}10%{opacity:.9}90%{opacity:.2}100%{opacity:0;transform:translateY(-100vh)scale(.4)}}
.logo{font-family:'Cinzel Decorative',serif;font-size:clamp(2.2rem,7vw,5rem);font-weight:900;
  background:linear-gradient(175deg,#fff9e0,var(--gold2) 28%,var(--gold) 55%,var(--gold3));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  filter:drop-shadow(0 4px 22px rgba(201,168,76,.55));animation:ls 3s ease-in-out infinite;letter-spacing:.08em;}
@keyframes ls{0%,100%{filter:drop-shadow(0 4px 22px rgba(201,168,76,.5))}50%{filter:drop-shadow(0 4px 44px rgba(240,208,112,.95))}}
.logo-sub{font-family:'Cinzel',serif;font-size:clamp(.55rem,1.3vw,.8rem);color:var(--muted);
  letter-spacing:.5em;text-transform:uppercase;margin:.4rem 0 1.5rem;}
.phase{display:none;flex-direction:column;align-items:center;gap:9px;width:min(560px,95vw);}
.phase.on{display:flex;}
.btn{font-family:'Cinzel',serif;font-weight:700;font-size:clamp(.75rem,1.4vw,.9rem);
  color:var(--dark);letter-spacing:.07em;padding:.75em 1.6em;border:none;cursor:pointer;
  background:linear-gradient(180deg,var(--gold2),var(--gold) 50%,var(--gold3));
  clip-path:polygon(6px 0%,100% 0%,100% calc(100% - 6px),calc(100% - 6px) 100%,0% 100%,0% 6px);
  transition:all var(--tr);box-shadow:0 4px 14px rgba(201,168,76,.28);width:100%;position:relative;overflow:hidden;}
.btn::after{content:'';position:absolute;top:-50%;left:-60%;width:35%;height:200%;background:rgba(255,255,255,.13);transform:skewX(-20deg);transition:left .4s;}
.btn:hover::after{left:160%;}
.btn:hover{transform:translateY(-2px);box-shadow:0 7px 24px rgba(201,168,76,.52);}
.btn:active{transform:scale(.97);}
.btn.sec{background:linear-gradient(180deg,var(--stone3),var(--stone2));color:var(--text);box-shadow:none;}
.btn.danger{background:linear-gradient(180deg,#aa2222,#882020);color:#fff;}
.btn2{display:grid;grid-template-columns:1fr 1fr;gap:9px;width:100%;}
/* Input fields */
.inp{width:100%;padding:9px 12px;background:#0a0706;color:var(--text);
  border:1px solid var(--gold3);border-radius:4px;font-family:'IM Fell English',serif;font-size:.9rem;outline:none;}
.inp:focus{border-color:var(--gold);}
.inp-label{font-family:'Cinzel',serif;font-size:.72rem;color:var(--muted);letter-spacing:.08em;text-align:left;width:100%;}
/* Class cards */
.cgrid{display:grid;grid-template-columns:repeat(2,1fr);gap:10px;width:100%;}
@media(min-width:500px){.cgrid{grid-template-columns:repeat(4,1fr);}}
.ccard{background:rgba(18,12,6,.97);border:2px solid rgba(201,168,76,.3);border-radius:8px;
  padding:14px 8px 10px;text-align:center;cursor:pointer;transition:all .22s;position:relative;overflow:hidden;}
.ccard::before{content:'';position:absolute;inset:0;background:radial-gradient(circle at 50% 0%,rgba(201,168,76,.07),transparent 65%);opacity:0;transition:opacity .3s;}
.ccard:hover::before,.ccard.on::before{opacity:1;}
.ccard:hover,.ccard.on{border-color:var(--gold);box-shadow:var(--gg);transform:translateY(-3px);}
.ccard-svg{width:72px;height:72px;margin:0 auto 8px;display:block;}
.cn{font-family:'Cinzel',serif;font-size:.82rem;color:var(--gold);}
.cd{font-size:.62rem;color:var(--muted);margin-top:3px;line-height:1.4;}
/* World cards */
.wgrid{display:grid;grid-template-columns:repeat(2,1fr);gap:10px;width:100%;}
@media(min-width:500px){.wgrid{grid-template-columns:repeat(4,1fr);}}
.wcard{background:rgba(18,12,6,.97);border:2px solid rgba(201,168,76,.28);border-radius:8px;
  padding:12px 7px;text-align:center;cursor:pointer;transition:all .22s;position:relative;overflow:hidden;}
.wcard:hover,.wcard.on{border-color:var(--gold);box-shadow:var(--gg);transform:translateY(-2px);}
.wcard-art{width:60px;height:60px;margin:0 auto 6px;display:block;border-radius:4px;}

/* ── HUD ── */
#hud{position:fixed;inset:0;z-index:10;pointer-events:none;display:none;}
#hud.on{display:block;}
.hbars{position:absolute;top:8px;left:8px;background:var(--ui-bg);border:var(--ui-b);
  border-radius:var(--r);padding:8px 12px;pointer-events:all;backdrop-filter:blur(8px);min-width:240px;}
.prow{display:flex;gap:9px;align-items:center;margin-bottom:7px;}
.port{width:48px;height:48px;border-radius:5px;border:2px solid var(--gold3);background:var(--stone);
  display:flex;align-items:center;justify-content:center;flex-shrink:0;
  cursor:pointer;transition:transform var(--tr);box-shadow:var(--gg);overflow:hidden;}
.port:hover{transform:scale(1.08);}
.nlv{font-family:'Cinzel',serif;font-size:.82rem;color:var(--gold);cursor:pointer;}
.nlv small{color:var(--muted);font-size:.62rem;display:block;}
.bwrap{display:flex;flex-direction:column;gap:4px;}
.brow{display:flex;align-items:center;gap:6px;}
.blbl{font-size:.58rem;letter-spacing:.05em;color:var(--muted);width:18px;text-transform:uppercase;}
.btrack{flex:1;height:9px;background:#080604;border:1px solid rgba(201,168,76,.18);border-radius:2px;overflow:hidden;}
.bfill{height:100%;border-radius:2px;transition:width .35s ease;}
.bfill.hp{background:linear-gradient(90deg,#5a0000,#cc2222,#ff4444);}
.bfill.mp{background:linear-gradient(90deg,#000a33,#1133aa,#3366ff);}
.bfill.xp{background:linear-gradient(90deg,#002211,#116633,#22ff88);}
.bval{font-size:.56rem;color:var(--muted);min-width:60px;text-align:right;}
.brow-buf{display:flex;gap:3px;margin-top:4px;flex-wrap:wrap;}
.bufic{width:22px;height:22px;border-radius:3px;background:var(--stone2);border:1px solid var(--gold3);
  display:flex;align-items:center;justify-content:center;font-size:.8rem;position:relative;}
.buft{position:absolute;bottom:0;left:0;right:0;height:3px;background:var(--gold);border-radius:0 0 3px 3px;}

/* Boss HP bar at top */
#boss-bar{position:absolute;top:0;left:0;right:0;pointer-events:none;z-index:50;
  padding:6px 14px 8px;background:rgba(5,2,2,.92);border-bottom:2px solid #aa2200;
  backdrop-filter:blur(6px);display:none;transform:translateY(-100%);transition:transform .4s cubic-bezier(.34,1.4,.64,1);}
#boss-bar.on{display:block;transform:translateY(0);}
.boss-name{font-family:'Cinzel Decorative',serif;font-size:.82rem;color:#ff5555;text-align:center;
  text-shadow:0 0 12px rgba(255,68,68,.7);letter-spacing:.1em;margin-bottom:4px;}
#boss-hp-track{width:100%;height:16px;background:#1a0000;border:1px solid #aa2200;border-radius:3px;overflow:hidden;}
#boss-hp-fill{height:100%;background:linear-gradient(90deg,#550000,#cc2200,#ff4422);transition:width .4s ease;
  position:relative;}
#boss-hp-fill::after{content:'';position:absolute;top:2px;left:0;right:0;height:4px;
  background:rgba(255,255,255,.15);border-radius:2px;}
.boss-hp-val{font-family:'Cinzel',serif;font-size:.7rem;color:#ff9999;text-align:center;margin-top:3px;}

/* Combo */
#combo{position:absolute;top:10px;left:50%;transform:translateX(-50%);text-align:center;
  pointer-events:none;opacity:0;transition:opacity .35s;}
#combo.on{opacity:1;}
.cbn{font-family:'Cinzel Decorative',serif;font-size:clamp(2rem,4vw,3.5rem);font-weight:900;
  background:linear-gradient(180deg,#fff,var(--gold2),var(--fire));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  filter:drop-shadow(0 0 12px rgba(255,170,50,.8));line-height:1;
  animation:cpop .28s cubic-bezier(.34,1.56,.64,1);}
@keyframes cpop{from{transform:scale(.5)}to{transform:scale(1)}}
.cbl{font-family:'Cinzel',serif;font-size:.75rem;letter-spacing:.3em;color:var(--gold);}

/* Minimap */
#mm{position:absolute;top:8px;right:8px;border:var(--ui-b);background:var(--dark);pointer-events:all;}
.mml{font-family:'Cinzel',serif;font-size:.55rem;letter-spacing:.07em;color:var(--muted);
  text-align:center;padding:2px 0;border-top:1px solid rgba(201,168,76,.18);}

/* Hotbar */
#hotbar{position:absolute;bottom:10px;left:50%;transform:translateX(-50%);
  display:flex;gap:4px;pointer-events:all;
  background:var(--ui-bg);border:var(--ui-b);border-radius:8px;padding:4px 7px;
  backdrop-filter:blur(8px);}
.skb{width:48px;height:48px;background:var(--stone);border:2px solid var(--gold3);
  border-radius:5px;position:relative;cursor:pointer;overflow:hidden;
  transition:all var(--tr);display:flex;align-items:center;justify-content:center;flex-direction:column;}
.skb:hover{border-color:var(--gold);transform:translateY(-3px);box-shadow:var(--gg);}
.ski{font-size:1.4rem;line-height:1;}
.skk{position:absolute;bottom:1px;right:3px;font-family:'Cinzel',serif;font-size:.48rem;color:var(--muted);}
.skc{position:absolute;top:2px;left:3px;font-size:.44rem;color:#4488ff;}
.cdov{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;
  font-family:'Cinzel',serif;font-size:.82rem;font-weight:700;color:#fff;border-radius:3px;background:rgba(0,0,0,0);}
.skb.cd .cdov{background:rgba(0,0,0,.65);}

/* Quick item bar */
#quickbar{position:absolute;bottom:68px;left:50%;transform:translateX(-50%);
  display:flex;gap:5px;pointer-events:all;}
.qib{width:38px;height:38px;background:rgba(10,6,2,.9);border:1px solid var(--gold3);
  border-radius:4px;cursor:pointer;display:flex;align-items:center;justify-content:center;
  font-size:1.2rem;position:relative;transition:all .15s;}
.qib:hover{border-color:var(--gold);transform:scale(1.1);}
.qib-count{position:absolute;bottom:1px;right:2px;font-size:.45rem;color:var(--gold);font-family:'Cinzel',serif;}

/* Action panel */
.hact{position:absolute;bottom:70px;right:10px;display:flex;flex-direction:column;gap:3px;pointer-events:all;}
.ab{font-family:'Cinzel',serif;font-size:.62rem;background:var(--ui-bg);border:var(--ui-b);
  color:var(--text);padding:4px 9px;border-radius:var(--r);cursor:pointer;
  backdrop-filter:blur(4px);transition:all var(--tr);white-space:nowrap;}
.ab:hover{border-color:var(--gold);background:rgba(26,16,6,.97);}
.ghud{position:absolute;bottom:70px;left:10px;background:var(--ui-bg);border:var(--ui-b);
  border-radius:var(--r);padding:5px 9px;font-family:'Cinzel',serif;font-size:.78rem;
  color:var(--gold);pointer-events:none;backdrop-filter:blur(4px);}
.pethud{position:absolute;bottom:94px;left:10px;background:var(--ui-bg);border:var(--ui-b);
  border-radius:var(--r);padding:4px 9px;font-size:.7rem;color:var(--pois);
  pointer-events:none;backdrop-filter:blur(4px);display:none;}
.pethud.on{display:block;}

/* Combat log */
#clog{position:absolute;bottom:70px;left:10px;width:255px;max-height:125px;overflow:hidden;pointer-events:none;}
.cl{font-size:.68rem;line-height:1.4;padding:2px 6px;background:rgba(0,0,0,.55);
  border-left:3px solid;margin-bottom:2px;animation:sli .25s ease;}
@keyframes sli{from{opacity:0;transform:translateX(-10px)}to{opacity:1;transform:none}}
.cl.dmg{color:#ff9999;border-color:var(--blood);}
.cl.heal{color:#66ffaa;border-color:#22aa66;}
.cl.xp{color:#ffdd66;border-color:var(--gold3);}
.cl.sys{color:var(--ice);border-color:#4488aa;}
.cl.boss{color:var(--fire);border-color:var(--fire);font-weight:700;}
.cl.loot{color:#ffcc00;border-color:#aa8800;}

/* ── MOBILE JOYSTICK ── */
#joy-zone{position:fixed;bottom:0;left:0;width:45%;height:42%;z-index:30;pointer-events:all;display:none;}
#joy-zone.mob{display:block;}
#joy-base{position:absolute;bottom:22px;left:22px;width:110px;height:110px;
  border-radius:50%;background:rgba(201,168,76,.08);border:2px solid rgba(201,168,76,.25);
  display:flex;align-items:center;justify-content:center;}
#joy-stick{position:absolute;width:46px;height:46px;border-radius:50%;
  background:radial-gradient(circle,rgba(201,168,76,.8),rgba(201,168,76,.3));
  border:2px solid var(--gold);top:50%;left:50%;transform:translate(-50%,-50%);
  box-shadow:0 0 14px rgba(201,168,76,.5);}
/* Mobile skill buttons ring */
#mob-skills{position:fixed;bottom:8px;right:8px;width:44%;height:50%;z-index:30;pointer-events:all;display:none;}
#mob-skills.mob{display:block;}
.mob-sk{position:absolute;width:52px;height:52px;border-radius:50%;
  background:rgba(10,6,2,.88);border:2px solid var(--gold3);
  display:flex;align-items:center;justify-content:center;font-size:1.5rem;
  cursor:pointer;transition:all .12s;box-shadow:0 2px 8px rgba(0,0,0,.5);}
.mob-sk:active{transform:scale(.88);background:rgba(201,168,76,.2);}
.mob-sk.cd{opacity:.55;}
/* Auto-attack button mobile */
#mob-atk{position:fixed;bottom:130px;right:8px;z-index:35;display:none;
  width:60px;height:60px;border-radius:50%;background:rgba(180,30,30,.9);
  border:2px solid #ff4444;font-size:1.6rem;align-items:center;justify-content:center;
  cursor:pointer;box-shadow:0 0 16px rgba(255,68,68,.5);pointer-events:all;}
#mob-atk.mob{display:flex;}
#mob-atk:active{transform:scale(.88);}

/* Portal grid */
.portal-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:14px;padding:4px;}
.portal-card{position:relative;border-radius:10px;overflow:hidden;cursor:pointer;height:180px;
  background:#050403;border:2px solid rgba(201,168,76,.25);
  transition:all .28s cubic-bezier(.34,1.4,.64,1);box-shadow:0 4px 20px rgba(0,0,0,.6);}
.portal-card:hover{transform:translateY(-5px) scale(1.02);border-color:var(--gold);
  box-shadow:0 12px 40px rgba(0,0,0,.8),0 0 25px rgba(201,168,76,.3);}
.portal-card.active-map{border-color:var(--gold2);box-shadow:0 0 28px rgba(240,208,80,.4);}
.portal-bg{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;}
.portal-overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,.92) 0%,rgba(0,0,0,.3) 55%,transparent 100%);}
.portal-shimmer{position:absolute;inset:0;opacity:0;background:radial-gradient(ellipse at 50% 30%,rgba(201,168,76,.18) 0%,transparent 65%);transition:opacity .3s;}
.portal-card:hover .portal-shimmer{opacity:1;}
.portal-info{position:absolute;bottom:0;left:0;right:0;padding:10px 12px 9px;z-index:2;}
.portal-name{font-family:'Cinzel Decorative',serif;font-size:.84rem;color:#fff;margin-bottom:3px;}
.portal-danger{font-family:'Cinzel',serif;font-size:.6rem;letter-spacing:.05em;display:flex;align-items:center;gap:5px;}
.portal-badge{display:inline-block;padding:2px 7px;border-radius:3px;font-size:.57rem;font-family:'Cinzel',serif;}
.pbadge-safe{background:rgba(34,170,100,.35);color:#44ffaa;border:1px solid rgba(34,170,100,.5);}
.pbadge-danger{background:rgba(180,30,20,.35);color:#ff8888;border:1px solid rgba(180,30,20,.5);}
.portal-visited{position:absolute;top:7px;right:7px;font-family:'Cinzel',serif;font-size:.53rem;
  color:var(--gold);background:rgba(0,0,0,.7);padding:2px 5px;border-radius:3px;border:1px solid rgba(201,168,76,.4);}
.portal-enter-btn{display:block;width:100%;margin-top:6px;padding:4px 0;text-align:center;
  font-family:'Cinzel',serif;font-size:.64rem;letter-spacing:.08em;color:var(--dark);
  background:linear-gradient(90deg,var(--gold3),var(--gold),var(--gold3));
  border:none;border-radius:3px;cursor:pointer;opacity:0;transform:translateY(4px);transition:opacity .2s,transform .2s;}
.portal-card:hover .portal-enter-btn{opacity:1;transform:translateY(0);}

/* Modals */
.modal{position:fixed;inset:0;z-index:200;display:none;align-items:center;justify-content:center;
  background:rgba(5,4,3,.86);backdrop-filter:blur(6px);}
.modal.on{display:flex;}
.mbox{background:var(--dark2);border:2px solid var(--gold3);border-radius:8px;padding:20px;
  width:min(780px,96vw);max-height:90vh;overflow-y:auto;
  box-shadow:0 0 60px rgba(0,0,0,.9),0 0 18px rgba(201,168,76,.22);
  animation:min .22s cubic-bezier(.34,1.56,.64,1);position:relative;}
@keyframes min{from{opacity:0;transform:scale(.88)}to{opacity:1;transform:scale(1)}}
.mt{font-family:'Cinzel Decorative',serif;font-size:1.2rem;color:var(--gold);
  text-align:center;margin-bottom:12px;padding-bottom:7px;border-bottom:1px solid rgba(201,168,76,.22);}
.mc{position:absolute;top:10px;right:11px;font-size:1.2rem;cursor:pointer;color:var(--muted);}
.mc:hover{color:var(--gold);}
.igrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(70px,1fr));gap:6px;margin:8px 0;}
.isl{width:70px;height:70px;background:var(--stone);border:var(--ui-b);border-radius:4px;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  cursor:pointer;transition:all var(--tr);font-size:.58rem;text-align:center;padding:3px;gap:2px;}
.isl:hover{border-color:var(--gold);box-shadow:var(--gg);}
.isl.eq{border-color:var(--gold2);box-shadow:var(--gg);}
.isl.emp{opacity:.22;cursor:default;}
.tag{font-size:.58rem;padding:1px 4px;border-radius:2px;font-family:'Cinzel',serif;}
.tag.common{background:#111;color:#aaa;}
.tag.rare{background:#1a2260;color:#6688ff;}
.tag.epic{background:#260d2a;color:#cc44ff;}
.tag.legend{background:#261800;color:var(--gold2);}
.sgrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(135px,1fr));gap:8px;}
.si{background:var(--stone);border:var(--ui-b);border-radius:4px;padding:10px;
  cursor:pointer;transition:all var(--tr);text-align:center;}
.si:hover{border-color:var(--gold);transform:translateY(-2px);}
.qi{background:var(--stone);border:var(--ui-b);border-radius:4px;padding:10px;margin-bottom:6px;}
.qi.done{border-color:#22aa66;background:rgba(0,50,22,.4);}
.qt{font-family:'Cinzel',serif;font-size:.84rem;color:var(--gold);}
.qd{font-size:.72rem;color:var(--muted);margin:3px 0;}
.qpw{height:5px;background:#111;border-radius:3px;overflow:hidden;margin-top:5px;}
.qpb{height:100%;background:linear-gradient(90deg,#005522,#22ff88);border-radius:3px;transition:width .3s;}
.stg{display:grid;grid-template-columns:1fr 1fr;gap:7px;}
.stb{background:var(--stone);border:var(--ui-b);border-radius:4px;padding:8px;}
.stl{font-size:.63rem;color:var(--muted);text-transform:uppercase;letter-spacing:.1em;}
.stv{font-family:'Cinzel',serif;font-size:1.25rem;color:var(--gold);}
.stbtn{font-family:'Cinzel',serif;font-size:.66rem;color:var(--dark);
  background:linear-gradient(180deg,var(--gold2),var(--gold));
  border:none;padding:3px 7px;border-radius:3px;cursor:pointer;}
.stbtn:hover{filter:brightness(1.2);}
.achi{display:flex;align-items:center;gap:10px;background:var(--stone);border:var(--ui-b);
  border-radius:4px;padding:9px;margin-bottom:5px;}
.achi.done{border-color:var(--gold);}
.tgrid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;}
.tnode{background:var(--stone);border:var(--ui-b);border-radius:50%;width:56px;height:56px;
  display:flex;align-items:center;justify-content:center;font-size:1.35rem;
  cursor:pointer;transition:all var(--tr);margin:auto;}
.tnode.unl{border-color:var(--gold);box-shadow:var(--gg);}
.tnode:hover{transform:scale(1.12);}
.fslot{width:74px;height:74px;background:var(--stone);border:var(--ui-b);border-radius:4px;
  display:flex;align-items:center;justify-content:center;font-size:1.65rem;
  cursor:pointer;border-style:dashed;transition:all var(--tr);}
.fslot.fill{border-style:solid;border-color:var(--gold);}
.gmb{display:flex;align-items:center;gap:8px;background:var(--stone);border-radius:4px;padding:7px;margin-bottom:4px;}
.ginp{width:100%;padding:7px;background:#0e0b07;color:var(--text);
  border:1px solid var(--gold3);border-radius:3px;font-family:'IM Fell English',serif;font-size:.86rem;outline:none;}
.ginp:focus{border-color:var(--gold);}
.rkr{display:flex;align-items:center;gap:9px;background:var(--stone);border:var(--ui-b);
  border-radius:4px;padding:8px 11px;margin-bottom:4px;}
.rkp{font-family:'Cinzel',serif;font-size:1rem;color:var(--gold);width:26px;}
.dgrid{display:flex;gap:7px;flex-wrap:wrap;justify-content:center;margin:12px 0;}
.dbox{width:64px;height:64px;background:var(--stone);border:var(--ui-b);border-radius:5px;
  display:flex;flex-direction:column;align-items:center;justify-content:center;gap:3px;
  cursor:pointer;transition:all var(--tr);font-size:.57rem;}
.dbox.claimed{opacity:.35;cursor:default;border-color:var(--dim);}
.dbox.today{border-color:var(--gold2);box-shadow:var(--gg);animation:dp 1.2s ease-in-out infinite;}
.dbox:not(.claimed):hover{border-color:var(--gold);transform:scale(1.05);}
@keyframes dp{0%,100%{box-shadow:0 0 8px rgba(201,168,76,.4)}50%{box-shadow:0 0 20px rgba(201,168,76,.9)}}

/* Boss warning */
#bwarn{position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);z-index:150;
  text-align:center;pointer-events:none;display:none;}
#bwarn.on{display:block;animation:bwin .4s ease;}
@keyframes bwin{from{opacity:0;transform:translate(-50%,-50%)scale(.5)}to{opacity:1;transform:translate(-50%,-50%)scale(1)}}
.bwt{font-family:'Cinzel Decorative',serif;font-size:clamp(1.7rem,3.5vw,3rem);font-weight:900;
  color:var(--blood2);text-shadow:0 0 25px rgba(204,34,34,.7);animation:bwp .55s ease-in-out infinite;}
@keyframes bwp{0%,100%{text-shadow:0 0 20px rgba(204,34,34,.7)}50%{text-shadow:0 0 48px rgba(255,68,68,.9)}}
#lvfl{position:fixed;inset:0;z-index:140;pointer-events:none;display:none;
  background:radial-gradient(ellipse 80% 80% at 50% 50%,rgba(255,215,65,.16),transparent 70%);
  animation:lvf 1.7s ease-out forwards;}
@keyframes lvf{0%{opacity:1}100%{opacity:0}}
#toasts{position:fixed;top:64px;left:50%;transform:translateX(-50%);
  display:flex;flex-direction:column;gap:5px;z-index:210;align-items:center;pointer-events:none;}
.toast{background:rgba(8,5,2,.97);border:var(--ui-b);border-radius:var(--r);
  padding:6px 16px;font-family:'Cinzel',serif;font-size:.78rem;color:var(--text);
  animation:tin .32s cubic-bezier(.34,1.56,.64,1) forwards;backdrop-filter:blur(8px);
  max-width:380px;text-align:center;}
@keyframes tin{from{opacity:0;transform:translateY(-16px)scale(.9)}to{opacity:1;transform:none}}
.fdmg{position:fixed;pointer-events:none;z-index:80;font-family:'Cinzel',serif;font-weight:900;
  text-shadow:1px 1px 0 #000,-1px -1px 0 #000;animation:fdu 1.1s ease-out forwards;}
@keyframes fdu{0%{opacity:1;transform:translateY(0)scale(1)}14%{transform:translateY(-12px)scale(1.2)}100%{opacity:0;transform:translateY(-65px)scale(.75)}}
.fdmg.crit{font-size:1.4rem;color:#fff;animation:fdc 1.25s ease-out forwards;}
@keyframes fdc{0%{opacity:1;transform:translateY(0)scale(.5)rotate(-5deg)}14%{transform:translateY(-18px)scale(1.55)rotate(4deg)}100%{opacity:0;transform:translateY(-85px)scale(.8)}}
.lootfx{position:fixed;pointer-events:none;z-index:82;font-size:1.7rem;animation:ldr 2.2s ease-out forwards;}
@keyframes ldr{0%{opacity:1;transform:translateY(0)scale(.7)}15%{transform:translateY(-15px)scale(1.3)}100%{opacity:0;transform:translateY(-85px)scale(.8)}}
#chat{position:fixed;bottom:70px;right:10px;width:255px;background:var(--ui-bg);
  border:var(--ui-b);border-radius:6px;backdrop-filter:blur(8px);z-index:20;
  display:none;flex-direction:column;overflow:hidden;}
#chat.on{display:flex;}
#chat-msgs{height:110px;overflow-y:auto;padding:7px;font-size:.68rem;line-height:1.55;}
#chat-in{width:100%;background:#0a0706;border:none;border-top:1px solid rgba(201,168,76,.18);
  color:var(--text);padding:6px 8px;font-size:.74rem;font-family:'IM Fell English',serif;outline:none;}
#end{position:fixed;inset:0;z-index:290;display:none;flex-direction:column;align-items:center;
  justify-content:center;background:rgba(5,4,3,.96);backdrop-filter:blur(10px);}
#end.on{display:flex;}
.et{font-family:'Cinzel Decorative',serif;font-size:clamp(2rem,5vw,4rem);font-weight:900;margin-bottom:1rem;}
.et.death{background:linear-gradient(180deg,#ff8888,#cc2222);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.et.win{background:linear-gradient(180deg,#fff5d0,var(--gold));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.estats{display:grid;grid-template-columns:repeat(3,1fr);gap:11px;margin:1.2rem 0 1.8rem;max-width:460px;width:90%;}
.esx{background:var(--stone2);border:var(--ui-b);border-radius:5px;padding:11px;text-align:center;}
.esv{font-family:'Cinzel',serif;font-size:1.7rem;color:var(--gold);}
.esl{font-size:.62rem;color:var(--muted);text-transform:uppercase;letter-spacing:.1em;}
.sep{height:1px;background:rgba(201,168,76,.18);margin:8px 0;}
::-webkit-scrollbar{width:4px;}
::-webkit-scrollbar-track{background:var(--dark);}
::-webkit-scrollbar-thumb{background:var(--gold3);border-radius:2px;}
/* Account form */
.acc-form{display:flex;flex-direction:column;gap:8px;width:100%;}
.acc-row{display:flex;gap:8px;width:100%;}
.skill-panel{background:rgba(18,12,6,.97);border:1px solid rgba(201,168,76,.25);border-radius:6px;padding:10px;margin-bottom:8px;}
.skill-panel h4{font-family:'Cinzel',serif;font-size:.8rem;color:var(--gold);margin-bottom:6px;text-align:center;}
.voc-skill{display:flex;align-items:center;gap:8px;padding:5px 7px;border-radius:4px;background:rgba(0,0,0,.3);margin-bottom:4px;}
.vs-icon{font-size:1.3rem;flex-shrink:0;}
.vs-info{flex:1;}
.vs-name{font-family:'Cinzel',serif;font-size:.73rem;color:var(--text);}
.vs-desc{font-size:.6rem;color:var(--muted);}
.vs-cost{font-size:.6rem;color:#4488ff;margin-left:auto;white-space:nowrap;}
/* Skill element colors */
.sk-fire{border-left:3px solid #ff4422;}
.sk-ice{border-left:3px solid #88ddff;}
.sk-light{border-left:3px solid #ffee44;}
.sk-dark{border-left:3px solid #8844cc;}
.sk-heal{border-left:3px solid #44ee88;}
.sk-earth{border-left:3px solid #aa8844;}
@media(max-width:600px){
  .hbars{min-width:190px;padding:6px 10px;}
  .hact{display:none;}
  #hotbar{display:none;}
  #clog{bottom:130px;}
  .ghud{bottom:130px;}
  .pethud{bottom:155px;}
  #quickbar{bottom:115px;}
  #boss-bar{padding:5px 10px 6px;}
}
</style>
</head>
