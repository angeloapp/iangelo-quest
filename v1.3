  log('🌟 ¡Bienvenido a iAngelo Quest V2, '+G.p.name+'!','sys');
  log('Click enemigos • WASD/Flechas mover • 1-6 habilidades','sys');
  setTimeout(()=>showDailyModal(),1500);
  setInterval(()=>{if(G&&G.running)saveGame();},30000);
  startFakeChat();
  lastT=performance.now();requestAnimationFrame(loop);
}

