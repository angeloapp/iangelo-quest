function drawMinimap(){
  if(!G)return;
  const mc=document.getElementById('mmc'),ctx=mc.getContext('2d');
  const m=MAPS[G.mapKey],tiles=G.allTiles[G.mapKey];
  const tw=mc.width/m.w,th=mc.height/m.h;
  ctx.clearRect(0,0,mc.width,mc.height);
  for(let y=0;y<m.h;y++)for(let x=0;x<m.w;x++){
    ctx.fillStyle=(tiles[y]&&tiles[y][x]===0)?m.floor:'#080808';ctx.fillRect(x*tw,y*th,tw+.5,th+.5);
  }
  G.enemies.forEach(en=>{if(en.dead)return;ctx.fillStyle=en.boss?'#ff4422':en.col;ctx.fillRect(en.px/T*tw-1.5,en.py/T*th-1.5,3,3);});
  G.fakePlayers.forEach(fp=>{if(fp.map!==G.mapKey)return;ctx.fillStyle=fp.col;ctx.fillRect(fp.px/T*tw-2,fp.py/T*th-2,4,4);});
  const p=G.p;ctx.fillStyle=CLASSES[p.cls].col;
  ctx.beginPath();ctx.arc(p.px/T*tw,p.py/T*th,4.2,0,Math.PI*2);ctx.fill();
  ctx.strokeStyle='#fff';ctx.lineWidth=1;ctx.stroke();
}

// ── Float damage & burst ──
function spawnFD(x,y,text,color,crit){
  if(!G)return;
  const el=document.createElement('div');el.className='fdmg'+(crit?' crit':'');
  el.style.left=(x-G.camX-18)+'px';el.style.top=(y-G.camY)+'px';
  el.style.color=color;el.style.fontSize=crit?'1.35rem':'.88rem';el.textContent=text;
  document.body.appendChild(el);setTimeout(()=>el.remove(),1200);
}
function burst(x,y,color,count){
  if(!G)return;
  ctxFx.save();
  for(let i=0;i<count;i++){
    const a=Math.random()*Math.PI*2,d=14+Math.random()*42;
    ctxFx.fillStyle=color+'99';ctxFx.beginPath();
    ctxFx.arc(x-G.camX+Math.cos(a)*d*.3,y-G.camY+Math.sin(a)*d*.3,2+Math.random()*3.5,0,Math.PI*2);ctxFx.fill();
  }
  ctxFx.restore();setTimeout(()=>ctxFx.clearRect(0,0,cvFx.width,cvFx.height),220);
}

