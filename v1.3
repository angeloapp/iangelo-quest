function buyItem(i){
  if(!G)return;const it=SHOP_ITEMS[i];
  if(G.p.gold<it.price){toast('💰 Oro insuficiente');return;}
  G.p.gold-=it.price;const item={...it,id:Date.now()};
  if(item.type==='consumable')item.count=1;
  G.p.inventory.push(item);toast('✅ '+it.name+' comprado!');renderShop();updateHUD();buildQuickbar();
}

// ── Forge ──
function renderForge(){
  let h='<div style="text-align:center;color:var(--muted);font-size:.78rem;margin-bottom:12px">Combina items para crear equipo legendario</div><div style="display:flex;flex-direction:column;gap:15px">';
  FORGE_RECIPES.forEach((rec,ri)=>{
    h+='<div style="background:var(--stone);border:var(--ui-b);border-radius:6px;padding:13px;text-align:center">'
      +'<div style="font-family:Cinzel,serif;color:var(--gold);margin-bottom:9px">'+rec.name+'</div>'
      +'<div style="display:flex;align-items:center;justify-content:center;gap:8px">';
    rec.mats.forEach((idx,mi)=>{
      if(mi>0)h+='<span style="color:var(--gold);font-size:1.1rem">+</span>';
      h+='<div class="fslot fill"><span style="font-size:1.55rem">'+SHOP_ITEMS[idx].icon+'</span></div>';
    });
    h+='<span style="color:var(--muted);font-size:1.2rem">→</span>'
      +'<div style="width:88px;height:88px;background:var(--stone2);border:2px solid var(--gold);border-radius:6px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:3px;box-shadow:0 0 14px rgba(201,168,76,.35)">'
      +'<span style="font-size:2.1rem">'+rec.result.icon+'</span>'
      +'<span style="font-size:.58rem;font-family:Cinzel,serif;color:var(--gold)">'+rec.result.name+'</span>'
      +'</div></div>'
      +'<button onclick="forgeItem('+ri+')" class="btn" style="margin-top:9px;font-size:.74rem;padding:.45em 1.3em;max-width:145px">⚒️ Forjar</button>'
      +'</div>';
  });
  h+='</div>';document.getElementById('forge-c').innerHTML=h;
}
function forgeItem(ri){if(!G)return;G.p.inventory.push({...FORGE_RECIPES[ri].result,id:Date.now()});toast('⚒️ '+FORGE_RECIPES[ri].result.name+' forjada!');renderForge();}

// ── Stats with portrait ──
function renderStats(){
  if(!G)return;const p=G.p;
  const c=CLASSES[p.cls];
  const mkS=(label,val,stat)=>{
    let h='<div class="stb"><div class="stl">'+label+'</div><div style="display:flex;align-items:center;gap:6px"><div class="stv">'+val+'</div>';
    if(stat&&p.statPts>0)h+='<button class="stbtn" onclick="allocate(\''+stat+'\')">+</button>';
    h+='</div></div>';return h;
  };
  document.getElementById('stats-c').innerHTML=
    '<div style="display:flex;gap:14px;flex-wrap:wrap;margin-bottom:12px;align-items:flex-start">'
    +'<div style="background:var(--stone);border:2px solid var(--gold3);border-radius:8px;padding:8px;text-align:center;min-width:100px">'
    +'<svg width="86" height="100" viewBox="0 0 72 80"><use href="#'+c.svgId+'"/></svg>'
    +'<div style="font-family:Cinzel,serif;font-size:.8rem;color:var(--gold);margin-top:4px">'+p.name+'</div>'
    +'<div style="font-size:.63rem;color:var(--muted)">'+c.name+' · Nv'+p.level+'</div>'
    +'<div style="font-size:.63rem;color:var(--gold);margin-top:3px">〔'+(p.title||'Sin título')+'〕</div>'
    +'</div>'
    +'<div class="stg" style="flex:1">'
    +mkS('Nivel',p.level)+mkS('Oro','💰'+p.gold)
    +mkS('Bajas',p.kills)+mkS('Daño Total',p.totalDmg)
    +mkS('Combo Máx',p.maxCombo+'x')+mkS('Mapas Visit.',G.visitedMaps.size)
    +mkS('Fuerza',p.str,'str')+mkS('Agilidad',p.agi,'agi')
    +mkS('Inteligencia',p.int,'int')+mkS('Vitalidad',p.vit,'vit')
    +'</div></div>'
    +'<div style="font-family:Cinzel,serif;color:var(--gold);margin-top:4px">Puntos libres: '+p.statPts+'</div>'
    +'<div style="height:1px;background:rgba(201,168,76,.18);margin:8px 0"></div>'
    +'<div style="display:flex;gap:8px;flex-wrap:wrap">'
    +'<button onclick="changeName()" class="btn" style="font-size:.74rem;padding:.4em 1.2em;max-width:180px">✏️ Cambiar Nombre</button>'
    +'<button onclick="openM(\'vocskills\')" class="btn sec" style="font-size:.74rem;padding:.4em 1.2em;max-width:180px">⚡ Ver Habilidades</button>'
    +'</div>';
  renderVocSkills();
}
function renderVocSkills(){
  const p=G?G.p:null;if(!p)return;
  const skills=getCurSkills();
  const c=CLASSES[p.cls];
  document.getElementById('vocskills-title').textContent='⚡ Habilidades de '+c.name;
  const elColors={fire:'sk-fire',ice:'sk-ice',light:'sk-light',dark:'sk-dark',heal:'sk-heal',earth:'sk-earth'};
  document.getElementById('vocskills-c').innerHTML=skills.map((s,i)=>`
    <div class="voc-skill ${elColors[s.el]||''}" style="margin-bottom:6px">
      <span class="vs-icon">${s.icon}</span>
      <div class="vs-info"><div class="vs-name">${i+1}. ${s.name}</div><div class="vs-desc">${s.desc}</div></div>
      <span class="vs-cost">${s.cost?s.cost+' MP':'Gratis'} · CD:${s.cd}s</span>
    </div>`).join('');
}
function allocate(stat){
  if(!G||G.p.statPts<=0)return;G.p.statPts--;const p=G.p;
  if(stat==='str'){p.str+=3;p.atkBase[1]+=6;}
  if(stat==='agi'){p.agi+=3;p.critChance=Math.min(.45,p.critChance+.02);p.speed+=5;}
  if(stat==='int'){p.int+=3;p.maxMp+=22;p.mp=p.maxMp;}
  if(stat==='vit'){p.vit+=3;p.maxHp+=42;p.hp=p.maxHp;}
  renderStats();updateHUD();
}
function changeName(){const n=prompt('Nuevo nombre:',G.p.name);if(n&&n.trim().length>1){G.p.name=n.trim();localStorage.setItem('iaqName',G.p.name);toast('Nombre cambiado a '+G.p.name);closeM('stats');}}

// ── Talents ──
function renderTalents(){
  if(!G)return;
  const icons=['🔥','⚡','❄️','☄️','💖','🛡️','🌑','👊','🏹','✨','🌋','💎'];
  const names=['Ardor','Relámpago','Escarcha','Caos','Sanación','Fortaleza','Sombra','Brutalidad','Precisión','Gracia','Apocalipsis','Maestría'];
  let h='<div style="font-family:Cinzel,serif;color:var(--gold);text-align:center;margin-bottom:9px">Puntos libres: '+G.p.statPts+'</div><div class="tgrid">';
  icons.forEach((ic,i)=>{
    h+='<div><div class="tnode '+(G.p.talents[i]>0?'unl':'')+'" onclick="unlockTalent('+i+')" title="'+names[i]+'">'+ic+'</div>'
      +'<div style="font-size:.56rem;text-align:center;color:var(--muted);margin-top:3px">'+names[i]+'</div>'
      +(G.p.talents[i]>0?'<div style="font-size:.54rem;text-align:center;color:var(--gold)">Nv'+G.p.talents[i]+'</div>':'')
      +'</div>';
  });
  h+='</div>';document.getElementById('talent-c').innerHTML=h;
}
function unlockTalent(i){if(!G||G.p.statPts<=0){toast('Sin puntos');return;}G.p.statPts--;G.p.talents[i]++;toast('🌟 Talento desbloqueado!');renderTalents();}

// ── Achievements ──
function renderAch(){
  if(!G)return;
  document.getElementById('ach-c').innerHTML=ACHIEVEMENTS_DB.map((a,i)=>
    '<div class="achi '+(G.p.achievements[i]?'done':'')+'">'
    +'<span style="font-size:1.8rem;flex-shrink:0">'+a.icon+'</span>'
    +'<div><div style="font-family:Cinzel,serif;font-size:.82rem;color:var(--gold)">'+a.name+'</div>'
    +'<div style="font-size:.68rem;color:var(--muted)">'+a.desc+'</div>'
    +(G.p.achievements[i]?'<div style="font-size:.63rem;color:var(--gold);margin-top:2px">✓ Título: 〔'+a.title+'〕</div>':'')
    +'</div></div>').join('');
}

// ── Guild ──
function renderGuild(){
  if(!G)return;
  const c=CLASSES[G.p.cls];
  // Get account code
  const accounts=getAccounts();
  const acc=accounts[(G.p.name||'').toLowerCase()];
  const myCode=acc?acc.code:'XXXXXX';

  let h='<div style="margin-bottom:9px">'
    +'<div style="font-family:Cinzel,serif;color:var(--gold);margin-bottom:5px">Nombre del Guild:</div>'
    +'<input class="ginp" id="ginp" value="'+(G.p.guild||'Los Legendarios')+'">'
    +'<button onclick="saveGuild()" class="btn" style="margin-top:7px;font-size:.74rem;padding:.4em 1.2em;max-width:155px">💾 Guardar Guild</button>'
    +'</div>'
    +'<div style="background:rgba(201,168,76,.08);border:1px solid rgba(201,168,76,.25);border-radius:6px;padding:10px;margin-bottom:10px;">'
    +'<div style="font-family:Cinzel,serif;font-size:.72rem;color:var(--muted);margin-bottom:4px">TU CÓDIGO DE RECLUTAMIENTO</div>'
    +'<div style="font-family:Cinzel,serif;font-size:1.6rem;color:var(--gold2);letter-spacing:.3em;text-align:center">'+myCode+'</div>'
    +'<div style="font-size:.62rem;color:var(--muted);text-align:center;margin-top:4px">Comparte este código con tus amigos para que se unan</div>'
    +'</div>'
    +'<div style="margin-bottom:10px;">'
    +'<div style="font-family:Cinzel,serif;color:var(--gold);margin-bottom:5px;font-size:.78rem">Reclutar con código:</div>'
    +'<div style="display:flex;gap:8px;">'
    +'<input class="ginp" id="recruit-code" placeholder="Código del amigo..." style="flex:1;letter-spacing:.2em;">'
    +'<button onclick="recruitMember()" class="btn" style="max-width:100px;font-size:.7rem;">+ Reclutar</button>'
    +'</div>'
    +'</div>'
    +'<div style="height:1px;background:rgba(201,168,76,.18);margin:9px 0"></div>'
    +'<div style="font-family:Cinzel,serif;color:var(--gold);margin-bottom:7px">Miembros del Guild</div>'
    // Player
    +'<div class="gmb">'
    +'<div style="width:32px;height:36px;flex-shrink:0"><svg width="32" height="36" viewBox="0 0 72 80"><use href="#'+c.svgId+'"/></svg></div>'
    +'<span style="font-family:Cinzel,serif">'+G.p.name+'</span>'
    +'<span style="margin-left:auto;color:var(--gold);font-size:.7rem">Lv'+G.p.level+' — Líder</span></div>';
  FAKE_PLAYERS.forEach(fp=>{
    h+='<div class="gmb"><div style="width:32px;height:36px;flex-shrink:0"><svg width="32" height="36" viewBox="0 0 72 80"><use href="#'+fp.svgId+'"/></svg></div>'
      +'<span style="font-family:Cinzel,serif;color:'+fp.col+'">'+fp.name+'</span>'
      +'<span style="margin-left:auto;color:var(--muted);font-size:.7rem">Lv'+fp.level+'</span></div>';
  });
  // Show recruited members
  const guild=JSON.parse(localStorage.getItem('iaqGuild_'+G.p.name)||'[]');
  guild.forEach(m=>{
    h+='<div class="gmb"><span style="font-size:1.2rem">⚔️</span>'
      +'<span style="font-family:Cinzel,serif;color:#88ffcc">'+m.name+'</span>'
      +'<span style="margin-left:auto;color:var(--muted);font-size:.7rem">Reclutado</span></div>';
  });
  document.getElementById('guild-c').innerHTML=h;
}
function saveGuild(){const v=document.getElementById('ginp');if(v&&v.value.trim()&&G)G.p.guild=v.value.trim();toast('🛡️ Guild actualizada');}
function recruitMember(){
  const code=document.getElementById('recruit-code').value.trim().toUpperCase();
  if(!code){toast('Ingresa un código');return;}
  const accounts=getAccounts();
  let found=null;
  Object.values(accounts).forEach(a=>{if(a.code===code)found=a;});
  if(!found){toast('Código no encontrado. Verifica con tu amigo.');return;}
  if(found.name===G.p.name){toast('No puedes reclutarte a ti mismo 😄');return;}
  const guildKey='iaqGuild_'+G.p.name;
  const guild=JSON.parse(localStorage.getItem(guildKey)||'[]');
  if(guild.find(m=>m.name===found.name)){toast(found.name+' ya está en el guild');return;}
  guild.push({name:found.name,code});
  localStorage.setItem(guildKey,JSON.stringify(guild));
  toast('🎉 '+found.name+' se unió al guild!',4000);
  document.getElementById('recruit-code').value='';
  renderGuild();
}

// ── Ranking ──
function renderRanking(){
  if(!G)return;
  const medals=['🥇','🥈','🥉','4','5','6'];
  const myRow={name:G.p.name,lv:G.p.level,score:G.score||0,cls:CLASSES[G.p.cls].name,isMe:true};
  const rows=[...RANK_FAKE,myRow].sort((a,b)=>b.score-a.score);
  document.getElementById('rank-c').innerHTML=rows.map((r,i)=>
    '<div class="rkr" style="'+(r.isMe?'border-color:var(--gold)':'')+'">'
    +'<span class="rkp">'+(medals[i]||i+1)+'</span>'
    +'<span style="font-family:Cinzel,serif;font-size:.82rem;flex:1;color:'+(r.isMe?'var(--gold)':'var(--text)')+'">'
    +r.name+(r.isMe?' ◀ tú':'')+'</span>'
    +'<span style="color:var(--muted);font-size:.68rem">'+r.cls+'</span>'
    +'<span style="color:var(--muted);font-size:.68rem;margin-left:6px">Lv'+r.lv+'</span>'
    +'<span style="color:var(--gold);font-size:.78rem;margin-left:8px">'+r.score+'</span></div>').join('');
}

// ── Daily ──
function showDailyModal(){if(!G)return;openM('daily');}
function renderDaily(){
  const today=new Date().toDateString();
  const saved=JSON.parse(localStorage.getItem('iaqDaily')||'{}');
  const claimed=saved.date===today;const day=saved.streak||1;
  let h='<div style="text-align:center;color:var(--muted);font-size:.8rem;margin-bottom:10px">'
    +(claimed?'✓ Ya reclamaste hoy. Vuelve mañana.':'¡Reclama tu recompensa de hoy!')+'</div><div class="dgrid">';
  DAILY_REWARDS.forEach((r,i)=>{
    const isClaimed=i+1<day,isToday=i+1===day&&!claimed;
    const cls='dbox'+(isClaimed?' claimed':'')+(isToday?' today':'');
    const onclick=isToday?' onclick="claimDaily('+i+')"':'';
    h+='<div class="'+cls+'"'+onclick+'>'
      +'<span style="font-size:1.35rem">'+r.icon+'</span>'
      +'<span style="color:var(--gold);font-size:.54rem">Día '+r.day+'</span>'
      +'<span style="color:var(--muted);font-size:.52rem">'+r.label+'</span></div>';
  });
  h+='</div><div style="text-align:center;font-size:.7rem;color:var(--muted)">Racha: '+day+' día(s)</div>';
  document.getElementById('daily-c').innerHTML=h;
}
function claimDaily(idx){
  if(!G)return;const today=new Date().toDateString();
  const saved=JSON.parse(localStorage.getItem('iaqDaily')||'{}');
  if(saved.date===today){toast('Ya reclamaste hoy');return;}
  const streak=Math.min(7,(saved.streak||0)+1);const next=streak>=7?1:streak+1;
  localStorage.setItem('iaqDaily',JSON.stringify({date:today,streak:next}));
  const r=DAILY_REWARDS[idx];
  if(r.type==='gold'){G.p.gold+=r.amount;toast('🎁 +'+r.amount+' Oro!');}
  if(r.type==='xp'){G.p.xp+=r.amount;checkLevelUp();toast('🎁 +'+r.amount+' XP!');}
  if(r.type==='item'){G.p.inventory.push({...r.item,id:Date.now()});toast('🎁 '+r.item.name+' añadido!');}
  updateHUD();renderDaily();buildQuickbar();
}

// ── Chat ──
function toggleChat(){document.getElementById('chat').classList.toggle('on');}
function sendChat(){
  const inp=document.getElementById('chat-in');if(!inp.value.trim())return;
  addChat(G?G.p.name:'Angelo',inp.value,G?CLASSES[G.p.cls].col:'#c9a84c');inp.value='';
}
function addChat(name,msg,col){
  const cm=document.getElementById('chat-msgs');const el=document.createElement('div');
  el.innerHTML='<span style="color:'+col+';font-family:Cinzel,serif;font-size:.68rem">'+name+':</span> '+msg;
  cm.appendChild(el);cm.scrollTop=cm.scrollHeight;
}
function startFakeChat(){
  const msgs=['¡Boss en el dungeon!','Alguien quiere trade?','Drop legendario! 🌟','V2 es épico 🔥','¡Combo x12!','Al nivel 8 🎉','La forja es OP','SVG monstruos son increíbles','¿Alguien en Volcán?','¡Lich Rey en el Abismo!'];
  setInterval(()=>{
    if(!G||!G.running)return;
    const fp=G.fakePlayers[Math.floor(Math.random()*G.fakePlayers.length)];
    addChat(fp.name,msgs[Math.floor(Math.random()*msgs.length)],fp.col);
  },5500);
}

// ── Save ──
function saveGame(){
  if(!G||!G.p)return;
  localStorage.setItem('iaqSave',JSON.stringify({p:G.p,quests:G.quests,mapKey:G.mapKey,score:G.score||0}));
  // Save to account if logged in
  const accounts=getAccounts();
  const key=(G.p.name||'').toLowerCase();
  if(accounts[key]){accounts[key].lastSeen=new Date().toISOString();saveAccounts(accounts);}
}

// ── Game over / Win ──
function gameOver(){
  if(!G)return;G.running=false;saveGame();hideBossBar();const p=G.p;
  document.getElementById('et').textContent='💀 Has Muerto';
  document.getElementById('et').className='et death';
  document.getElementById('estats').innerHTML=
    [['Nivel',p.level],['Bajas',p.kills],['Oro',p.gold],['Daño',p.totalDmg],['Combo',p.maxCombo+'x'],['Score',G.score]]
    .map(([l,v])=>'<div class="esx"><div class="esv">'+v+'</div><div class="esl">'+l+'</div></div>').join('');
  document.getElementById('end').classList.add('on');
}
function gameWin(){
  if(!G)return;G.running=false;saveGame();
  document.getElementById('et').textContent='🏆 ¡Victoria!';
  document.getElementById('et').className='et win';
  document.getElementById('estats').innerHTML=
    [['Nivel',G.p.level],['Bajas',G.p.kills],['Oro',G.p.gold],['Score',G.score],['Combo',G.p.maxCombo+'x'],['Mapas',G.visitedMaps.size]]
    .map(([l,v])=>'<div class="esx"><div class="esv">'+v+'</div><div class="esl">'+l+'</div></div>').join('');
  document.getElementById('end').classList.add('on');
}
function backToTitle(){
  document.getElementById('end').classList.remove('on');
  document.getElementById('hud').classList.remove('on');
  document.getElementById('title').style.display='flex';
  G=null;wxParts=[];logLines=[];shakeAmt=0;
  cvW.style.transform='';hideBossBar();
  document.getElementById('hotbar').innerHTML='';
  document.getElementById('clog').innerHTML='';
  goPhase(0);requestAnimationFrame(bgLoop);
}

// ══════════════════════════════════════════
//  MAIN LOOP
// ══════════════════════════════════════════
function loop(ts){
  const dt=Math.min((ts-lastT)/1000,.1);lastT=ts;
  drawBg();
  if(G&&G.running){applyJoystick();update(dt);drawWorld();}
  requestAnimationFrame(loop);
}
function bgLoop(ts){drawBg();if(!G)requestAnimationFrame(bgLoop);}

// Boot
preloadSVGs().then(()=>{requestAnimationFrame(bgLoop);});
</script>
</body>
</html>
