  G.p.px=T*3+T*.5;G.p.py=T*3+T*.5;G.camX=0;G.camY=0;
  G.weather=MAPS[key].wx||'clear';G.spawnTimer=0;G.activeBoss=null;
  hideBossBar();
  if(!G.visitedMaps.has(key)){G.visitedMaps.add(key);checkQuest('map');}
  document.getElementById('mml').textContent=MAPS[key].name;
  if(!MAPS[key].safe)for(let i=0;i<4;i++)spawnEnemy();
  log('🌌 Has viajado a '+MAPS[key].name,'sys');closeM('teleport');
}

