// ── ACCOUNT SYSTEM ──
function getAccounts(){return JSON.parse(localStorage.getItem('iaqAccounts')||'{}');}
function saveAccounts(a){localStorage.setItem('iaqAccounts',JSON.stringify(a));}
function hashPass(s){let h=0;for(let i=0;i<s.length;i++){h=((h<<5)-h)+s.charCodeAt(i);h|=0;}return h.toString(36);}
function genCode(){
  const chars='ABCDEFGHJKMNPQRSTUVWXYZ23456789';
  let code='';for(let i=0;i<6;i++)code+=chars[Math.floor(Math.random()*chars.length)];
  document.getElementById('reg-code').value=code;
}
function doRegister(){
  const user=document.getElementById('reg-user').value.trim();
  const pass=document.getElementById('reg-pass').value;
  const code=document.getElementById('reg-code').value;
  const msg=document.getElementById('reg-msg');
  if(!user||user.length<2){msg.textContent='El nombre debe tener al menos 2 caracteres';return;}
  if(!pass||pass.length<4){msg.textContent='Contraseña de al menos 4 caracteres';return;}
  if(!code){msg.textContent='Genera un código de partida';return;}
  const accounts=getAccounts();
  if(accounts[user.toLowerCase()]){msg.textContent='Ese nombre ya existe';return;}
  accounts[user.toLowerCase()]={name:user,hash:hashPass(pass),code,created:Date.now()};
  saveAccounts(accounts);
  localStorage.setItem('iaqName',user);
  msg.style.color='#44ff88';msg.textContent='✓ Cuenta creada! Iniciando sesión...';
  setTimeout(()=>{goPhase(1,'nueva');},1000);
}
function doLogin(){
  const user=document.getElementById('login-user').value.trim();
  const pass=document.getElementById('login-pass').value;
  const msg=document.getElementById('login-msg');
  const accounts=getAccounts();
  const acc=accounts[user.toLowerCase()];
  if(!acc){msg.textContent='Usuario no encontrado';return;}
  if(acc.hash!==hashPass(pass)){msg.textContent='Contraseña incorrecta';return;}
  localStorage.setItem('iaqName',acc.name);
  msg.style.color='#44ff88';msg.textContent='✓ ¡Bienvenido de vuelta, '+acc.name+'!';
  const save=localStorage.getItem('iaqSave');
  setTimeout(()=>{if(save){tryLoad();}else{goPhase(1,'nueva');}},800);
}

